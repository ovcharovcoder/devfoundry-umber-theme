  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7A7166" }
    },
    {
      "name": "Strings",
      "scope": ["string"],
      "settings": { "foreground": "#8FBF7A" }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": { "foreground": "#D97C85" }
    },
    {
